{
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm --filter @workspace/api-server run start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "nixpacks": {
    "buildPhase": "pnpm install --no-frozen-lockfile && pnpm run build"
  }
}
